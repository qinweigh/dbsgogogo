+DROP TABLE IF EXISTS t1;
+# TC1: Variable visibility
+SELECT @@global.binlog_large_commit_threshold;
+@@global.binlog_large_commit_threshold
+65536
+SHOW VARIABLES LIKE 'binlog_large_commit_threshold';
+Variable_name	Value
+binlog_large_commit_threshold	65536
+RESET MASTER;
+CREATE TABLE t1 (id INT AUTO_INCREMENT PRIMARY KEY, payload VARCHAR(200)) ENGINE=InnoDB;
+# TC2: Small transaction (in-memory only, normal path)
+BEGIN;
+INSERT INTO t1 VALUES (NULL, 'small_row_1');
+INSERT INTO t1 VALUES (NULL, 'small_row_2');
+COMMIT;
+include/assert.inc [TC2: 2 rows committed]
+# TC3: Transaction spills but size < threshold (normal path)
+BEGIN;
+INSERT INTO t1 VALUES (NULL, REPEAT('x', 200));
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+COMMIT;
+include/assert.inc [TC3: rows committed after spill]
+# TC4: Large transaction triggers commit_by_rename
+FLUSH BINARY LOGS;

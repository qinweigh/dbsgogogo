+/**
+  Commit a large transaction by renaming its cache file to a new binlog file.
+
+  Instead of copying the transaction data from the binlog cache to the binlog
+  file, this function renames the cache file directly to become the new binlog
+  file. This avoids blocking other commits during the write of a large
+  transaction.
+
+  The cache file has a reserved area at the beginning (reserve_bytes). This
+  function fills that area with: binlog file header (FDE + Previous_GTIDs) +
+  GTID event + optional Ignorable padding event, then renames the file.
+
+  @param thd          Current thread
+  @param cache_data   Binlog cache containing the transaction data
+  @param gtid_event   GTID event for this transaction
+
+  @retval false  Success
+  @retval true   Error (caller should fall back to normal commit path)
+*/
+bool MYSQL_BIN_LOG::commit_by_rename(THD *thd, binlog_cache_data *cache_data,
+                                     Gtid_log_event *gtid_event) {
+  DBUG_TRACE;
+  mysql_mutex_assert_owner(&LOCK_log);
+
+  if (rpl_encryption.is_enabled()) return true;
+
+  Binlog_cache_storage *cache = cache_data->get_cache();
+  const char *cache_path = cache->tmp_file_name();
+  const size_t reserve_bytes = get_binlog_cache_reserve_bytes();
+  const my_off_t trx_len = cache_data->get_byte_position();
+
+  cache_data->update_commit_statistics();
+  if (cache->flush_sync_and_close_file()) return true;
+
+  /*
+    Phase 1 — Rotate binlog, read the new file header, serialize GTID.
+    Validate that everything fits into reserve_bytes BEFORE modifying the
+    cache file.  If it does not fit, fall back to the normal commit path.
+  */
+  if (new_file_without_locking(nullptr)) return true;
+
+  const my_off_t header_len = m_binlog_file->position();
+  if (m_binlog_file->flush()) return true;
+
+  std::unique_ptr<uchar[]> header_buf(new (std::nothrow) uchar[header_len]);
+  if (!header_buf) return true;
+
+  File new_fd = mysql_file_open(m_key_file_log, log_file_name, O_RDONLY,
+                                MYF(MY_WME));
+  if (new_fd < 0) return true;
+  bool read_ok =
+      mysql_file_read(new_fd, header_buf.get(), header_len,
+                      MYF(MY_WME | MY_NABP)) == 0;
+  mysql_file_close(new_fd, MYF(0));
+  if (!read_ok) return true;
+
+  gtid_event->common_header->log_pos = reserve_bytes;
+  StringBuffer_ostream<256> gtid_buf;
+  if (binary_event_serialize(gtid_event, &gtid_buf)) return true;
+  const size_t gtid_len = gtid_buf.length();
+
+  const bool have_checksum =
+      binlog_checksum_options != binary_log::BINLOG_CHECKSUM_ALG_OFF;
+  const size_t checksum_len = have_checksum ? BINLOG_CHECKSUM_LEN : 0;
+  const size_t min_pad_event_size = LOG_EVENT_HEADER_LEN + checksum_len;
+  const size_t used = static_cast<size_t>(header_len) + gtid_len;
+
+  if (used > reserve_bytes) return true;
+
+  const size_t gap = reserve_bytes - used;
+  if (gap > 0 && gap < min_pad_event_size) return true;
+
+  /*
+    Phase 2 — Write binlog header + GTID + padding into the cache file's
+    reserved area.
+  */
+  File cache_fd = mysql_file_open(m_key_file_log_cache, cache_path,
+                                  O_RDWR, MYF(MY_WME));
+  if (cache_fd < 0) return true;
+
+  bool err = false;
+  if (mysql_file_seek(cache_fd, 0, MY_SEEK_SET, MYF(MY_WME)) ==
+      MY_FILEPOS_ERROR)
+    err = true;
+
+  if (!err &&
+      mysql_file_write(cache_fd, header_buf.get(), header_len,
+                       MYF(MY_WME | MY_NABP)) != 0)
+    err = true;
+
+  if (!err &&
+      mysql_file_write(cache_fd,
+                       pointer_cast<const uchar *>(gtid_buf.ptr()), gtid_len,
+                       MYF(MY_WME | MY_NABP)) != 0)
+    err = true;
+
+  if (!err && gap > 0) {
+    /*
+      Fill the gap with a valid Ignorable_log_event so that sequential
+      binlog readers never encounter raw zero bytes between events.
+    */
+    uchar pad_header[LOG_EVENT_HEADER_LEN];
+    memset(pad_header, 0, sizeof(pad_header));
+    int4store(pad_header + 0, 0);
+    pad_header[EVENT_TYPE_OFFSET] =
+        static_cast<uchar>(binary_log::IGNORABLE_LOG_EVENT);
+    int4store(pad_header + SERVER_ID_OFFSET, server_id);
+    int4store(pad_header + EVENT_LEN_OFFSET,
+              static_cast<uint32>(gap - checksum_len));
+    int4store(pad_header + LOG_POS_OFFSET,
+              static_cast<uint32>(reserve_bytes));
+    int2store(pad_header + FLAGS_OFFSET, LOG_EVENT_IGNORABLE_F);
+
+    if (mysql_file_write(cache_fd, pad_header, LOG_EVENT_HEADER_LEN,
+                         MYF(MY_WME | MY_NABP)) != 0)
+      err = true;
+
+    const size_t body_len = gap - LOG_EVENT_HEADER_LEN - checksum_len;
+    if (!err && body_len > 0) {
+      std::unique_ptr<uchar[]> body(new (std::nothrow) uchar[body_len]());
+      if (!body)
+        err = true;
+      else if (mysql_file_write(cache_fd, body.get(), body_len,
+                                MYF(MY_WME | MY_NABP)) != 0)
+        err = true;
+    }
+
+    if (!err && have_checksum) {
+      ha_checksum crc = checksum_crc32(0, pad_header, LOG_EVENT_HEADER_LEN);
+      if (body_len > 0) {
+        std::unique_ptr<uchar[]> zbuf(new (std::nothrow) uchar[body_len]());
+        if (!zbuf)
+          err = true;
+        else
+          crc = checksum_crc32(crc, zbuf.get(), body_len);
+      }
+      if (!err) {
+        uchar crc_buf[BINLOG_CHECKSUM_LEN];
+        int4store(crc_buf, crc);
+        if (mysql_file_write(cache_fd, crc_buf, BINLOG_CHECKSUM_LEN,
+                             MYF(MY_WME | MY_NABP)) != 0)
+          err = true;
+      }
+    }
+  }
+
+  mysql_file_close(cache_fd, MYF(0));
+  if (err) return true;
+
+  /*
+    Phase 3 — Atomically replace the new (empty) binlog file with the
+    cache file.  Rename old binlog to a .bak first so that a crash between
+    the two renames does not lose the file.
+  */
+  char bak_path[FN_REFLEN + 4];
+  snprintf(bak_path, sizeof(bak_path), "%s.bak", log_file_name);
+  m_binlog_file->close();
+
+  if (my_rename(log_file_name, bak_path, MYF(MY_WME))) return true;
+
+  if (my_rename(cache_path, log_file_name, MYF(MY_WME))) {
+    (void)my_rename(bak_path, log_file_name, MYF(MY_WME));
+    return true;
+  }
+
+  (void)my_delete(bak_path, MYF(0));
+
+  std::unique_ptr<Binlog_ofile> new_ofile(Binlog_ofile::open_existing(
+      m_key_file_log, log_file_name,
+      static_cast<myf>(MY_WME | MY_WAIT_IF_FULL)));
+  if (!new_ofile) return true;
+  const my_off_t file_size = reserve_bytes + trx_len;
+  if (new_ofile->set_position(file_size)) return true;
+
+  delete m_binlog_file;
+  m_binlog_file = new_ofile.release();
+  bytes_written += (file_size - static_cast<my_off_t>(header_len));
+  update_thd_next_event_pos(thd);
+  update_binlog_end_pos();
+  return false;
+}

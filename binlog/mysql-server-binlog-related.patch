diff --git a/mysql-test/suite/binlog_nogtid/t/binlog_large_commit_threshold.test b/mysql-test/suite/binlog_nogtid/t/binlog_large_commit_threshold.test
new file mode 100644
index 00000000..3bf79a54
--- /dev/null
+++ b/mysql-test/suite/binlog_nogtid/t/binlog_large_commit_threshold.test
@@ -0,0 +1,184 @@
+# ==== Purpose ====
+#
+# Verify the commit-by-rename optimisation controlled by
+# binlog_large_commit_threshold.  When a transaction's binlog cache
+# spills to disk and the cache size >= threshold, the server renames
+# the cache file to a new binlog file instead of copying, avoiding
+# blocking other commits during the write.
+#
+# The server is started with --binlog-large-commit-threshold=65536 and
+# --binlog-cache-size=32768 (via .opt file) so that:
+#   - #binlog_cache_files directory is created at startup
+#   - reserve_bytes=4096 is used when opening trx cache
+#   - transactions > 32K spill to disk
+#   - transactions >= 64K trigger commit_by_rename
+#
+# ==== Coverage ====
+#
+# TC1: Variable visibility and dynamic change
+# TC2: Small transaction stays in memory (normal path)
+# TC3: Transaction spills to disk but < threshold (normal path)
+# TC4: Transaction spills and >= threshold (commit_by_rename path)
+# TC5: Second commit after commit_by_rename (reset with file==-1)
+# TC6: Rollback after spill then new commit (reset with file>=0)
+# TC7: Disable threshold dynamically, verify normal path resumes
+# TC8: Binlog produced by commit_by_rename is readable by mysqlbinlog
+
+--source include/have_log_bin.inc
+--source include/have_binlog_format_row.inc
+
+--disable_warnings
+DROP TABLE IF EXISTS t1;
+--enable_warnings
+
+# =====================================================================
+# TC1: Variable visibility and dynamic change
+# =====================================================================
+--echo # TC1: Variable visibility
+SELECT @@global.binlog_large_commit_threshold;
+SHOW VARIABLES LIKE 'binlog_large_commit_threshold';
+
+RESET MASTER;
+
+CREATE TABLE t1 (id INT AUTO_INCREMENT PRIMARY KEY, payload VARCHAR(200)) ENGINE=InnoDB;
+
+# =====================================================================
+# TC2: Small transaction stays in memory, has_renameable_file()=false
+# =====================================================================
+--echo # TC2: Small transaction (in-memory only, normal path)
+BEGIN;
+INSERT INTO t1 VALUES (NULL, 'small_row_1');
+INSERT INTO t1 VALUES (NULL, 'small_row_2');
+COMMIT;
+
+# Verify rows committed
+--let $count= `SELECT COUNT(*) FROM t1`
+--let $assert_text= TC2: 2 rows committed
+--let $assert_cond= $count = 2
+--source include/assert.inc
+
+# =====================================================================
+# TC3: Spills to disk but cache_size < threshold (normal path)
+#      binlog_cache_size=32K, threshold=64K
+#      Generate ~40K of data: spills but < 64K
+# =====================================================================
+--echo # TC3: Transaction spills but size < threshold (normal path)
+BEGIN;
+INSERT INTO t1 VALUES (NULL, REPEAT('x', 200));
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+INSERT INTO t1 SELECT NULL, payload FROM t1;
+COMMIT;
+
+--let $count= `SELECT COUNT(*) FROM t1`
+--let $assert_text= TC3: rows committed after spill
+--let $assert_cond= $count > 2
+--source include/assert.inc
+
+# =====================================================================
+# TC4: Spills and >= threshold → commit_by_rename
+#      New connection so binlog_cache_mngr::init() picks up current
+#      cache_files_dir and reserve_bytes.
+# =====================================================================
+--echo # TC4: Large transaction triggers commit_by_rename
+FLUSH BINARY LOGS;
+
+connect (conn_rename, localhost, root, , test);
+
+# Fill enough data to exceed 64K when committed
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('A', 190) FROM t1 LIMIT 200;
+INSERT INTO t1 SELECT NULL, REPEAT('B', 190) FROM t1 LIMIT 200;
+COMMIT;
+
+--echo # Verify binlog events are valid after commit_by_rename
+--let $binlog_file= LAST
+--let $binlog_limit= 5
+--source include/show_binlog_events.inc
+
+# =====================================================================
+# TC5: Second commit after commit_by_rename
+#      reset() was called with file==-1 after rename; next txn should
+#      get a new cache file and work correctly.
+# =====================================================================
+--echo # TC5: Second commit after commit_by_rename (reset file==-1)
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('C', 190) FROM t1 LIMIT 200;
+COMMIT;
+
+--let $count= `SELECT COUNT(*) FROM t1`
+--let $assert_text= TC5: rows committed in second large txn
+--let $assert_cond= $count > 400
+--source include/assert.inc
+
+connection default;
+disconnect conn_rename;
+
+# =====================================================================
+# TC6: Rollback after spill, then new commit
+#      Verifies reset() with file>=0 path (truncate + chsize with
+#      reserve) works correctly.
+# =====================================================================
+--echo # TC6: Rollback after spill, then new commit
+connect (conn_rollback, localhost, root, , test);
+
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('R', 190) FROM t1 LIMIT 300;
+ROLLBACK;
+
+# Next commit must succeed on the same connection (cache properly reset)
+BEGIN;
+INSERT INTO t1 VALUES (NULL, 'after_rollback');
+COMMIT;
+
+--let $val= `SELECT payload FROM t1 WHERE payload = 'after_rollback' LIMIT 1`
+--let $assert_text= TC6: row after rollback committed
+--let $assert_cond= "$val" = "after_rollback"
+--source include/assert.inc
+
+connection default;
+disconnect conn_rollback;
+
+# =====================================================================
+# TC7: Disable threshold dynamically, verify normal path resumes
+# =====================================================================
+--echo # TC7: Disable threshold, normal path resumes
+SET GLOBAL binlog_large_commit_threshold = 0;
+FLUSH BINARY LOGS;
+
+connect (conn_disabled, localhost, root, , test);
+
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('D', 190) FROM t1 LIMIT 200;
+COMMIT;
+
+--let $count= `SELECT COUNT(*) FROM t1 WHERE payload LIKE 'DDD%'`
+--let $assert_text= TC7: rows committed with threshold disabled
+--let $assert_cond= $count > 0
+--source include/assert.inc
+
+connection default;
+disconnect conn_disabled;
+
+# Restore threshold
+SET GLOBAL binlog_large_commit_threshold = 65536;
+
+# =====================================================================
+# TC8: Binlog from commit_by_rename is readable by mysqlbinlog
+# =====================================================================
+--echo # TC8: mysqlbinlog can parse binlog produced by commit_by_rename

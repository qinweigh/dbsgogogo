+int IO_CACHE_binlog_cache_storage::create_file_callback(IO_CACHE *info,
+                                                        void *arg) {
+  auto *storage = static_cast<IO_CACHE_binlog_cache_storage *>(arg);
+  const char *dir = storage->m_create_file_dir;
+  const char *prefix = storage->m_create_file_prefix;
+  const size_t reserve = storage->m_file_reserved_bytes;
+  if (!dir || !prefix || reserve == 0) return -1;
+
+  char path[FN_REFLEN];
+  File fd = create_temp_file(path, dir, prefix, 0600, KEEP_FILE, MYF(MY_WME));
+  if (fd < 0) return -1;
+
+  if (reserve > 0) {
+    std::unique_ptr<uchar[]> zeros(
+        new (std::nothrow) uchar[std::min(reserve, size_t{4096})]());
+    if (!zeros) {
+      mysql_file_close(fd, MYF(0));
+      my_delete(path, MYF(0));
+      return -1;
+    }
+    size_t written = 0;
+    while (written < reserve) {
+      size_t chunk = std::min(reserve - written, size_t{4096});
+      if (mysql_file_write(fd, zeros.get(), chunk, MYF(MY_WME + MY_NABP))) {
+        mysql_file_close(fd, MYF(0));
+        my_delete(path, MYF(0));
+        return -1;
+      }
+      written += chunk;
+    }
+  }
+
+  info->file = fd;
+  info->pos_in_file = reserve;
+  info->seek_not_done = true;
+  strmake(storage->m_tmp_file_path, path, sizeof(storage->m_tmp_file_path) - 1);
+  return 0;
+}

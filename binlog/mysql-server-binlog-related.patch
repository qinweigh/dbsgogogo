+binlog.000002	#	Query	#	#	use `test`; CREATE TABLE t1 (id INT AUTO_INCREMENT PRIMARY KEY, payload VARCHAR(200)) ENGINE=InnoDB
+binlog.000002	#	Query	#	#	BEGIN
+# TC5: Second commit after commit_by_rename (reset file==-1)
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('C', 190) FROM t1 LIMIT 200;
+COMMIT;
+include/assert.inc [TC5: rows committed in second large txn]
+# TC6: Rollback after spill, then new commit
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('R', 190) FROM t1 LIMIT 300;
+ROLLBACK;
+BEGIN;
+INSERT INTO t1 VALUES (NULL, 'after_rollback');
+COMMIT;
+include/assert.inc [TC6: row after rollback committed]
+# TC7: Disable threshold, normal path resumes

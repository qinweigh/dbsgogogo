diff --git a/mysql-test/suite/binlog_nogtid/r/binlog_large_commit_threshold.result b/mysql-test/suite/binlog_nogtid/r/binlog_large_commit_threshold.result
new file mode 100644
index 00000000..9f201d5c
--- /dev/null
+++ b/mysql-test/suite/binlog_nogtid/r/binlog_large_commit_threshold.result
@@ -0,0 +1,126 @@
+# ----------------------------------------------------------------------
+# 1. Show variable and default; threshold=0 (feature disabled)
+# ----------------------------------------------------------------------
+SHOW VARIABLES LIKE 'binlog_large_commit_threshold';
+Variable_name	Value
+binlog_large_commit_threshold	134217728
+SET GLOBAL binlog_large_commit_threshold = 0;
+RESET MASTER;
+CREATE TABLE t1 (a INT PRIMARY KEY AUTO_INCREMENT, b VARCHAR(100)) ENGINE=InnoDB;
+SET SESSION binlog_cache_size = 32768;
+INSERT INTO t1 VALUES (NULL, REPEAT('x', 50));
+INSERT INTO t1 SELECT NULL, REPEAT('y', 50) FROM t1;
+INSERT INTO t1 SELECT NULL, REPEAT('z', 50) FROM t1;
+INSERT INTO t1 SELECT NULL, REPEAT('a', 50) FROM t1;
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('b', 50) FROM t1 LIMIT 2000;
+COMMIT;
+Log_name	Pos	Event_type	Server_id	End_log_pos	Info
+binlog.000001	#	Query	#	#	use `test`; CREATE TABLE t1 (a INT PRIMARY KEY AUTO_INCREMENT, b VARCHAR(100)) ENGINE=InnoDB
+binlog.000001	#	Query	#	#	BEGIN
+binlog.000001	#	Table_map	#	#	table_id: # (test.t1)
+binlog.000001	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000001	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000001	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000001	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000001	#	Query	#	#	BEGIN
+binlog.000001	#	Table_map	#	#	table_id: # (test.t1)
+binlog.000001	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000001	#	Xid	#	#	COMMIT /* XID */
+# ----------------------------------------------------------------------
+# 2. threshold > 0, small trx that does not spill (in-memory only)
+#    has_renameable_file() false => normal path
+# ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = 65536;
+FLUSH BINARY LOGS;
+SET SESSION binlog_cache_size = 1048576;
+CREATE TABLE t2 (a INT PRIMARY KEY, c VARCHAR(80)) ENGINE=InnoDB;
+BEGIN;
+INSERT INTO t2 VALUES (1, 'small');
+INSERT INTO t2 VALUES (2, 'txn');
+COMMIT;
+Log_name	Pos	Event_type	Server_id	End_log_pos	Info
+binlog.000002	#	Query	#	#	use `test`; CREATE TABLE t2 (a INT PRIMARY KEY, c VARCHAR(80)) ENGINE=InnoDB
+binlog.000002	#	Query	#	#	BEGIN
+binlog.000002	#	Table_map	#	#	table_id: # (test.t2)
+binlog.000002	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000002	#	Xid	#	#	COMMIT /* XID */
+# ----------------------------------------------------------------------
+# 3. threshold > 0, trx spills but size < threshold (normal path)
+# ----------------------------------------------------------------------
+SET SESSION binlog_cache_size = 32768;
+SET GLOBAL binlog_large_commit_threshold = 128 * 1024 * 1024;
+FLUSH BINARY LOGS;
+BEGIN;
+INSERT INTO t2 SELECT a + 10, c FROM t2;
+INSERT INTO t2 SELECT a + 20, c FROM t2;
+INSERT INTO t2 SELECT a + 30, REPEAT(c, 10) FROM t2;
+INSERT INTO t2 SELECT a + 40, REPEAT(c, 20) FROM t2;
+INSERT INTO t2 SELECT a + 50, REPEAT(c, 30) FROM t2;
+COMMIT;
+Log_name	Pos	Event_type	Server_id	End_log_pos	Info
+binlog.000003	#	Query	#	#	BEGIN
+binlog.000003	#	Table_map	#	#	table_id: # (test.t2)
+binlog.000003	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000003	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000003	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000003	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000003	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000003	#	Xid	#	#	COMMIT /* XID */
+# ----------------------------------------------------------------------
+# 4. commit_by_rename: threshold 64K, trx spills and size >= 64K
+#    New connection so trx cache inited with dir + reserve
+# ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = 65536;
+FLUSH BINARY LOGS;
+SET SESSION binlog_cache_size = 32768;
+CREATE TABLE IF NOT EXISTS t_commit_rename (id INT PRIMARY KEY, payload VARCHAR(200)) ENGINE=InnoDB;
+BEGIN;
+INSERT INTO t_commit_rename VALUES (1, REPEAT('a', 100));
+INSERT INTO t_commit_rename SELECT id + 1, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 2, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 4, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 8, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 16, payload FROM t_commit_rename;
+COMMIT;
+Log_name	Pos	Event_type	Server_id	End_log_pos	Info
+binlog.000004	#	Query	#	#	use `test`; CREATE TABLE IF NOT EXISTS t_commit_rename (id INT PRIMARY KEY, payload VARCHAR(200)) ENGINE=InnoDB
+binlog.000004	#	Query	#	#	BEGIN
+binlog.000004	#	Table_map	#	#	table_id: # (test.t_commit_rename)
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Xid	#	#	COMMIT /* XID */
+BEGIN;
+INSERT INTO t_commit_rename SELECT id + 100, payload FROM t_commit_rename LIMIT 20;
+COMMIT;
+Log_name	Pos	Event_type	Server_id	End_log_pos	Info
+binlog.000004	#	Query	#	#	BEGIN
+binlog.000004	#	Table_map	#	#	table_id: # (test.t_commit_rename)
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Xid	#	#	COMMIT /* XID */
+# ----------------------------------------------------------------------
+# 5. Rollback after spill: reset() with file>=0, truncate+chsize (reserve)
+# ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = 65536;
+FLUSH BINARY LOGS;
+SET SESSION binlog_cache_size = 32768;
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('r', 80) FROM t1 LIMIT 1500;
+ROLLBACK;
+BEGIN;
+INSERT INTO t1 VALUES (NULL, 'after_rollback');
+COMMIT;
+Log_name	Pos	Event_type	Server_id	End_log_pos	Info
+binlog.000004	#	Query	#	#	BEGIN
+binlog.000004	#	Table_map	#	#	table_id: # (test.t1)
+binlog.000004	#	Write_rows	#	#	table_id: # flags: STMT_END_F
+binlog.000004	#	Xid	#	#	COMMIT /* XID */
+# ----------------------------------------------------------------------
+# 6. Restore and cleanup
+# ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = DEFAULT;
+DROP TABLE IF EXISTS t1, t2, t_commit_rename;
diff --git a/mysql-test/suite/binlog_nogtid/t/binlog_large_commit_threshold.test b/mysql-test/suite/binlog_nogtid/t/binlog_large_commit_threshold.test
new file mode 100644
index 00000000..f65b94ea
--- /dev/null
+++ b/mysql-test/suite/binlog_nogtid/t/binlog_large_commit_threshold.test
@@ -0,0 +1,168 @@
+# ==== Purpose ====
+#
+# Test binlog_large_commit_threshold: when a large transaction's binlog
+# cache is >= threshold and was written to a file in #binlog_cache_files,
+# the server uses commit-by-rename (rename cache file to new binlog)
+# instead of copy. Covers:
+# - threshold=0: feature disabled, normal write path
+# - threshold>0, small trx (no spill): normal path, has_renameable_file() false
+# - threshold>0, trx spills but size < threshold: normal path
+# - threshold>0, trx spills and size >= threshold: commit_by_rename path
+# - init_binlog_cache_files_dir (create/clear #binlog_cache_files)
+# - reset() after commit-by-rename (file==-1, no chsize)
+# - reset() after spill then rollback (file>=0, truncate with reserve)
+#
+# ==== Implementation ====
+#
+# - Branch coverage for: init_binlog_cache_files_dir (threshold==0 skip;
+#   dir exists clear; dir not exist mkdir), get_binlog_cache_reserve_bytes
+#   (0 vs 4096), write_transaction (commit_by_rename vs normal), commit_by_rename
+#   success path, IO_CACHE_binlog_cache_storage open with/without reserve,
+#   create_file_callback, has_renameable_file, flush_sync_and_close_file,
+#   reset (file==-1 vs file>=0).
+#
+# ==== References ====
+#
+# MDEV-32014 (MariaDB), dbsgogogo/binlog/prompt.md
+#
+
+--source include/have_log_bin.inc
+--source include/have_binlog_format_row.inc
+
+--let $_have_bct= query_get_value(SHOW GLOBAL VARIABLES LIKE 'binlog_large_commit_threshold', Variable_name, 1)
+if (!$_have_bct) {
+  --skip Test requires binlog_large_commit_threshold (build with commit-by-rename support)
+}
+
+--disable_warnings
+DROP TABLE IF EXISTS t1, t2;
+--enable_warnings
+
+--echo # ----------------------------------------------------------------------
+--echo # 1. Show variable and default; threshold=0 (feature disabled)
+--echo # ----------------------------------------------------------------------
+SHOW VARIABLES LIKE 'binlog_large_commit_threshold';
+SET GLOBAL binlog_large_commit_threshold = 0;
+RESET MASTER;
+
+CREATE TABLE t1 (a INT PRIMARY KEY AUTO_INCREMENT, b VARCHAR(100)) ENGINE=InnoDB;
+
+-- Large transactional txn that spills to disk; with threshold=0 we use normal
+-- path (no #binlog_cache_files, reserve=0, no commit_by_rename).
+SET SESSION binlog_cache_size = 32768;
+INSERT INTO t1 VALUES (NULL, REPEAT('x', 50));
+INSERT INTO t1 SELECT NULL, REPEAT('y', 50) FROM t1;
+INSERT INTO t1 SELECT NULL, REPEAT('z', 50) FROM t1;
+INSERT INTO t1 SELECT NULL, REPEAT('a', 50) FROM t1;
+-- ~2000 rows, each row event ~50+ bytes => > 64K, spills
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('b', 50) FROM t1 LIMIT 2000;
+COMMIT;
+
+-- Verify binlog is valid (normal path produced correct log)
+--let $binlog_file= LAST
+--let $binlog_limit= 20
+--source include/show_binlog_events.inc
+
+--echo # ----------------------------------------------------------------------
+--echo # 2. threshold > 0, small trx that does not spill (in-memory only)
+--echo #    has_renameable_file() false => normal path
+--echo # ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = 65536;
+FLUSH BINARY LOGS;
+SET SESSION binlog_cache_size = 1048576;
+CREATE TABLE t2 (a INT PRIMARY KEY, c VARCHAR(80)) ENGINE=InnoDB;
+BEGIN;
+INSERT INTO t2 VALUES (1, 'small');
+INSERT INTO t2 VALUES (2, 'txn');
+COMMIT;
+
+--let $binlog_file= LAST
+--let $binlog_limit= 15
+--source include/show_binlog_events.inc
+
+--echo # ----------------------------------------------------------------------
+--echo # 3. threshold > 0, trx spills but size < threshold (normal path)
+--echo # ----------------------------------------------------------------------
+SET SESSION binlog_cache_size = 32768;
+-- Threshold 128M; txn ~100K so below threshold
+SET GLOBAL binlog_large_commit_threshold = 128 * 1024 * 1024;
+FLUSH BINARY LOGS;
+
+BEGIN;
+INSERT INTO t2 SELECT a + 10, c FROM t2;
+INSERT INTO t2 SELECT a + 20, c FROM t2;
+INSERT INTO t2 SELECT a + 30, REPEAT(c, 10) FROM t2;
+INSERT INTO t2 SELECT a + 40, REPEAT(c, 20) FROM t2;
+INSERT INTO t2 SELECT a + 50, REPEAT(c, 30) FROM t2;
+COMMIT;
+
+--let $binlog_file= LAST
+--let $binlog_limit= 15
+--source include/show_binlog_events.inc
+
+--echo # ----------------------------------------------------------------------
+--echo # 4. commit_by_rename: threshold 64K, trx spills and size >= 64K
+--echo #    New connection so trx cache inited with dir + reserve
+--echo # ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = 65536;
+FLUSH BINARY LOGS;
+
+-- New connection so binlog_cache_mngr::init() uses current dir + reserve
+connect (commit_rename_conn, localhost, root, , test);
+
+SET SESSION binlog_cache_size = 32768;
+CREATE TABLE IF NOT EXISTS t_commit_rename (id INT PRIMARY KEY, payload VARCHAR(200)) ENGINE=InnoDB;
+BEGIN;
+INSERT INTO t_commit_rename VALUES (1, REPEAT('a', 100));
+INSERT INTO t_commit_rename SELECT id + 1, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 2, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 4, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 8, payload FROM t_commit_rename;
+INSERT INTO t_commit_rename SELECT id + 16, payload FROM t_commit_rename;
+-- 1+1+2+4+8+16 = 32 rows * ~100+ bytes + events overhead => well over 64K
+COMMIT;
+
+-- Verify binlog is valid after commit_by_rename (no corrupted data)
+--let $binlog_file= LAST
+--let $binlog_limit= 25
+--source include/show_binlog_events.inc
+
+-- Second large txn in same session: reset() was called with file==-1 after
+-- commit_by_rename; next txn gets new cache file and can trigger rename again
+BEGIN;
+INSERT INTO t_commit_rename SELECT id + 100, payload FROM t_commit_rename LIMIT 20;
+COMMIT;
+
+--let $binlog_file= LAST
+--let $binlog_limit= 30
+--source include/show_binlog_events.inc
+
+connection default;
+disconnect commit_rename_conn;
+
+--echo # ----------------------------------------------------------------------
+--echo # 5. Rollback after spill: reset() with file>=0, truncate+chsize (reserve)
+--echo # ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = 65536;
+FLUSH BINARY LOGS;
+SET SESSION binlog_cache_size = 32768;
+
+BEGIN;
+INSERT INTO t1 SELECT NULL, REPEAT('r', 80) FROM t1 LIMIT 1500;
+ROLLBACK;
+
+-- Next commit should work (cache was reset with reserve path)
+BEGIN;
+INSERT INTO t1 VALUES (NULL, 'after_rollback');
+COMMIT;
+
+--let $binlog_file= LAST
+--let $binlog_limit= 10
+--source include/show_binlog_events.inc
+
+--echo # ----------------------------------------------------------------------
+--echo # 6. Restore and cleanup
+--echo # ----------------------------------------------------------------------
+SET GLOBAL binlog_large_commit_threshold = DEFAULT;
+DROP TABLE IF EXISTS t1, t2, t_commit_rename;

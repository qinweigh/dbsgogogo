+/** Name of directory under binlog dir for cache files used by commit-by-rename. */
+static const char *BINLOG_CACHE_FILES_DIR = "#binlog_cache_files";
+
+bool MYSQL_BIN_LOG::init_binlog_cache_files_dir() {
+  if (is_relay_log || opt_binlog_large_commit_threshold == 0) {
+    m_binlog_cache_files_dir[0] = '\0';
+    return false;
+  }
+  size_t dlen = dirname_length(log_file_name);
+  if (dlen + strlen(BINLOG_CACHE_FILES_DIR) + 3 > FN_REFLEN) {
+    m_binlog_cache_files_dir[0] = '\0';
+    return false;
+  }
+  strmake(m_binlog_cache_files_dir, log_file_name, dlen);
+  strcat(m_binlog_cache_files_dir, "/");
+  strcat(m_binlog_cache_files_dir, BINLOG_CACHE_FILES_DIR);
+
+  if (my_access(m_binlog_cache_files_dir, F_OK) == 0) {
+    MY_DIR *dir = my_dir(m_binlog_cache_files_dir, MYF(MY_WME));
+    if (dir) {
+      for (uint i = 0; i < dir->number_off_files; i++) {
+        const char *fname = dir->dir_entry[i].name;
+        if (fname[0] == '.' && (fname[1] == '\0' || (fname[1] == '.' && fname[2] == '\0')))
+          continue;
+        char path[FN_REFLEN];
+        fn_format(path, fname, m_binlog_cache_files_dir, "", MYF(0));
+        (void)my_delete(path, MYF(MY_WME));
+      }
+      my_dirend(dir);
+    }
+  } else {
+    if (my_mkdir(m_binlog_cache_files_dir, 0777, MYF(MY_WME)) < 0) {
+      char errbuf[MYSYS_STRERROR_SIZE];
+      LogErr(ERROR_LEVEL, ER_CANT_CREATE_FILE, m_binlog_cache_files_dir, errno,
+             my_strerror(errbuf, sizeof(errbuf), errno));
+      m_binlog_cache_files_dir[0] = '\0';
+      return true;
+    }
+  }
+  return false;
+}

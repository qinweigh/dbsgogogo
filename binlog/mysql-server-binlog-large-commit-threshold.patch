+bool MYSQL_BIN_LOG::commit_by_rename(THD *thd, binlog_cache_data *cache_data,
+                                     Gtid_log_event *gtid_event) {
+  DBUG_TRACE;
+  mysql_mutex_assert_owner(&LOCK_log);
+  Binlog_cache_storage *cache = cache_data->get_cache();
+  const char *cache_path = cache->tmp_file_name();
+  const size_t reserve_bytes = get_binlog_cache_reserve_bytes();
+  const my_off_t trx_len = cache_data->get_byte_position();
+
+  if (cache->flush_sync_and_close_file()) return true;
+
+  if (new_file_without_locking(nullptr)) return true;
+
+  const my_off_t header_len = m_binlog_file->position();
+  if (m_binlog_file->flush()) return true;
+
+  std::unique_ptr<uchar[]> header_buf(new uchar[header_len]);
+  File new_fd = mysql_file_open(m_key_file_log, log_file_name, O_RDONLY,
+                                MYF(MY_WME));
+  if (new_fd < 0) return true;
+  bool read_ok = mysql_file_read(new_fd, header_buf.get(), header_len,
+                                MYF(MY_WME + MY_NABP)) == static_cast<size_t>(header_len);
+  mysql_file_close(new_fd, MYF(0));
+  if (!read_ok) return true;
+
+  /* end_log_pos for Gtid must be the position of the next event (trx data). */
+  gtid_event->common_header->log_pos = reserve_bytes;
+  StringBuffer_ostream<256> gtid_buf;
+  if (binary_event_serialize(gtid_event, &gtid_buf)) return true;
+  const size_t gtid_len = gtid_buf.length();
+
+  File cache_fd = mysql_file_open(m_key_file_log_cache, cache_path,
+                                 O_RDWR, MYF(MY_WME));
+  if (cache_fd < 0) return true;
+
+  bool err = false;
+  if (mysql_file_seek(cache_fd, 0, MY_SEEK_SET, MYF(MY_WME)) == MY_FILEPOS_ERROR)
+    err = true;
+  if (!err && mysql_file_write(cache_fd, header_buf.get(), header_len,
+                               MYF(MY_WME + MY_NABP)) != header_len)
+    err = true;
+  if (!err &&
+      mysql_file_write(cache_fd,
+                      pointer_cast<const uchar *>(gtid_buf.ptr()), gtid_len,
+                      MYF(MY_WME + MY_NABP)) != gtid_len)
+    err = true;
+  if (!err && header_len + gtid_len < reserve_bytes) {
+    const size_t pad = reserve_bytes - (header_len + gtid_len);
+    std::unique_ptr<uchar[]> zeros(new uchar[pad]());
+    if (mysql_file_write(cache_fd, zeros.get(), pad, MYF(MY_WME + MY_NABP)) != pad)
+      err = true;
+  }
+  mysql_file_close(cache_fd, MYF(0));
+  if (err) return true;
+
+  m_binlog_file->close();
+  (void)my_delete(log_file_name, MYF(MY_WME));
+
+  if (my_rename(cache_path, log_file_name, MYF(MY_WME))) return true;
+
+  std::unique_ptr<Binlog_ofile> new_ofile(Binlog_ofile::open_existing(
+      m_key_file_log, log_file_name,
+      static_cast<myf>(MY_WME | MY_WAIT_IF_FULL)));
+  if (!new_ofile) return true;
+  const my_off_t file_size = reserve_bytes + trx_len;
+  if (new_ofile->set_position(file_size)) return true;
+
+  delete m_binlog_file;
+  m_binlog_file = new_ofile.release();
+  bytes_written += (file_size - header_len);
+  update_thd_next_event_pos(thd);
+  update_binlog_end_pos();
+  return false;
+}

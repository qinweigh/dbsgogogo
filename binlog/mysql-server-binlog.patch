+#ifndef BINLOG_LARGE_COMMIT_H_INCLUDED
+#define BINLOG_LARGE_COMMIT_H_INCLUDED
+
+#include "my_inttypes.h"
+#include "my_io.h"
+
+/**
+  Default reserved bytes at the beginning of binlog cache file.
+  Must be large enough for: BIN_LOG_HEADER_SIZE + FDE + Previous_gtids_event
+  + Gtid_log_event. Aligned to IO_SIZE (512).
+*/
+static constexpr uint32_t BINLOG_CACHE_RESERVE_DEFAULT = 4096;
+
+extern ulonglong opt_binlog_large_commit_threshold;
+extern char binlog_cache_dir[FN_REFLEN];
+
+/**
+  Initialize the #binlog_cache_files directory. Create it if not exists,
+  otherwise clean up stale cache files from previous server instance.
+
+  @retval false  Success.
+  @retval true   Error.
+*/
+bool init_binlog_cache_dir();
+
+/**
+  Get the number of bytes to reserve at the beginning of binlog cache files.
+  This is recalculated each time a new binlog file is opened.
+*/
+uint32_t get_binlog_cache_reserve_bytes();
+
+/**
+  Update the reserve bytes value based on the current binlog header size.
+
+  @param header_len  Total length of binlog header events (FDE + Previous_gtids)
+*/
+void set_binlog_cache_reserve_bytes(uint32_t header_len);
+
+#endif  // BINLOG_LARGE_COMMIT_H_INCLUDED

+/* =====================================================
+   IO_CACHE_binlog_cache_storage: large commit support
+   ===================================================== */
+
+bool IO_CACHE_binlog_cache_storage::init_file_with_reserve() {
+  if (m_io_cache.file != -1) return false;
+
+  uint32_t reserve = get_binlog_cache_reserve_bytes();
+  if (reserve == 0) return false;
+
+  /*
+    Build a unique file name using the ML_ prefix and the object address.
+    This guarantees uniqueness per session.
+  */
+  char name[FN_REFLEN];
+  snprintf(name, FN_REFLEN, "%s/ML_%llu", m_io_cache.dir,
+           (ulonglong)(uintptr_t)this);
+
+  File fd = mysql_file_open(0, name, O_CREAT | O_RDWR | O_TRUNC,
+                            MYF(MY_WME));
+  if (fd < 0) return true;
+
+  m_io_cache.file = fd;
+  m_file_reserved_bytes = reserve;
+
+  /* Seek past the reserved region so normal writes start after it. */
+  m_io_cache.pos_in_file = m_file_reserved_bytes;
+  m_io_cache.seek_not_done = 1;
+
+  return false;
+}
+
+bool IO_CACHE_binlog_cache_storage::sync_to_disk() {
+  if (m_io_cache.file == -1) return true;
+  if (my_b_flush_io_cache(&m_io_cache, 1)) return true;
+  if (mysql_file_sync(m_io_cache.file, MYF(0))) return true;
+  return false;
+}
+
+my_off_t IO_CACHE_binlog_cache_storage::file_data_length() const {
+  return my_b_tell(&m_io_cache);
+}
+
+void IO_CACHE_binlog_cache_storage::detach_temp_file() {
+  if (m_io_cache.file != -1) {
+    mysql_file_close(m_io_cache.file, MYF(0));
+    m_io_cache.file = -1;
+  }
+  m_file_reserved_bytes = 0;
+  /*
+    Reset the IO_CACHE to a clean WRITE state. truncate(0) will handle
+    reinit_io_cache properly.
+  */
+  (void)truncate(0);
+}

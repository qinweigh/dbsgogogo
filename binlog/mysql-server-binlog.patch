+/**
+  Check whether the current transaction qualifies for the commit-by-rename
+  optimization.
+
+  Conditions:
+  - binlog_large_commit_threshold > 0
+  - Cache size exceeds the threshold
+  - Cache file is on disk (not purely in-memory)
+  - Reserved space has been allocated in the cache file
+  - Binlog encryption is disabled
+  - Binlog checksums are disabled (MVP restriction)
+*/
+static bool should_commit_by_rename(THD *, binlog_cache_data *cache_data) {
+  if (opt_binlog_large_commit_threshold == 0) return false;
+
+  my_off_t cache_size = cache_data->get_byte_position();
+  if (cache_size <= opt_binlog_large_commit_threshold) return false;
+
+  Binlog_cache_storage *cache = cache_data->get_cache();
+
+  if (cache->disk_writes() == 0) return false;
+  if (cache->file_reserved_bytes() == 0) return false;
+  if (rpl_encryption.is_enabled()) return false;
+
+  if (binlog_checksum_options != binary_log::BINLOG_CHECKSUM_ALG_OFF)
+    return false;
+
+  return true;
+}
+
+/**
+  Write a raw IGNORABLE_LOG_EVENT to fill a gap in the binlog file.
+  The event body is all zeros.
+
+  @param fd         File descriptor to write to
+  @param offset     Offset in the file where the event starts
+  @param event_len  Total event length (header + body, no checksum)
+  @param end_pos    The end_log_pos to set (= offset + event_len)
+
+  @retval false  Success
+  @retval true   Error
+*/
+static bool write_ignorable_filler(File fd, my_off_t offset, uint32 event_len,
+                                   uint32 end_pos) {
+  uchar header[LOG_EVENT_HEADER_LEN];
+  memset(header, 0, sizeof(header));
+
+  /* timestamp = 0 */
+  int4store(header, 0);
+  header[EVENT_TYPE_OFFSET] = binary_log::IGNORABLE_LOG_EVENT;
+  int4store(header + SERVER_ID_OFFSET, server_id);
+  int4store(header + EVENT_LEN_OFFSET, event_len);
+  int4store(header + LOG_POS_OFFSET, end_pos);
+  int2store(header + FLAGS_OFFSET, LOG_EVENT_IGNORABLE_F);
+
+  if (mysql_file_pwrite(fd, header, LOG_EVENT_HEADER_LEN, offset,
+                        MYF(MY_WME | MY_NABP)))
+    return true;
+
+  /* Write zero body if event is larger than just the header */
+  if (event_len > LOG_EVENT_HEADER_LEN) {
+    uint32 body_len = event_len - LOG_EVENT_HEADER_LEN;
+    uchar zeros[IO_SIZE];
+    memset(zeros, 0, sizeof(zeros));
+    my_off_t written = 0;
+    my_off_t body_offset = offset + LOG_EVENT_HEADER_LEN;
+    while (written < body_len) {
+      uint32 chunk = std::min(static_cast<uint32>(sizeof(zeros)),
+                              static_cast<uint32>(body_len - written));
+      if (mysql_file_pwrite(fd, zeros, chunk, body_offset + written,
+                            MYF(MY_WME | MY_NABP)))
+        return true;
+      written += chunk;
+    }
+  }
+  return false;
+}
+
+/**
+  Fix up end_log_pos for all events in the cache file's data region.
+  Events in the cache have end_log_pos = 0. After rename, they need
+  correct absolute positions in the final binlog file.
+
+  Only valid when binlog checksums are OFF (no CRC to recompute).
+
+  @param fd            File descriptor of the cache file
+  @param data_offset   Start offset of event data in the file
+  @param data_end      End offset (= total file size)
+
+  @retval false  Success
+  @retval true   Error
+*/
+static bool fixup_event_positions(File fd, my_off_t data_offset,
+                                  my_off_t data_end) {
+  uchar buf[4];
+  my_off_t pos = data_offset;
+
+  while (pos < data_end) {
+    /* Read event_len at offset pos + EVENT_LEN_OFFSET */
+    if (mysql_file_pread(fd, buf, 4, pos + EVENT_LEN_OFFSET, MYF(MY_WME)) != 4)
+      return true;
+    uint32 event_len = uint4korr(buf);
+    if (event_len < LOG_EVENT_HEADER_LEN || pos + event_len > data_end)
+      return true;
+
+    /* Write correct end_log_pos = pos + event_len */
+    uint32 end_log_pos = static_cast<uint32>(pos + event_len);
+    int4store(buf, end_log_pos);
+    if (mysql_file_pwrite(fd, buf, 4, pos + LOG_POS_OFFSET,
+                          MYF(MY_WME | MY_NABP)))
+      return true;
+
+    pos += event_len;
+  }
+  return false;
+}
+
+/**
+  Commit a large transaction by renaming its binlog cache temp file
+  to become the next binlog file. This avoids copying potentially
+  gigabytes of data while holding LOCK_log.
+
+  High-level flow:
+  1. Sync cache file to disk
+  2. Acquire LOCK_log, assign GTID
+  3. Rotate binlog (creates new binlog with header events)
+  4. Copy header from new binlog into cache file's reserved area
+  5. Serialize GTID event into cache file
+  6. Write filler event for any gap in reserved area
+  7. Fix end_log_pos in all transaction events
+  8. Close + delete new binlog, rename cache -> binlog
+  9. Reopen the renamed file as the active binlog
+  10. Engine commit, GTID state update
+
+  @param thd          Current thread
+  @param all          true for real commit, false for statement commit
+  @param skip_commit  If true, skip ha_commit_low
+
+  @retval 0    Success
+  @retval -1   Not applicable, caller should fall through to ordered_commit
+  @retval >0   Error
+*/
+int MYSQL_BIN_LOG::commit_by_rename(THD *thd, bool all, bool skip_commit) {
+  DBUG_TRACE;
+
+  binlog_cache_mngr *cache_mngr = thd_get_cache_mngr(thd);
+  if (cache_mngr == nullptr) return -1;
+
+  binlog_cache_data *cache_data = &cache_mngr->trx_cache;
+  Binlog_cache_storage *cache = cache_data->get_cache();
+  IO_CACHE *io_cache = cache->get_io_cache();
+  File cache_fd = io_cache->file;
+  if (cache_fd < 0) return -1;
+
+  const char *cache_path = cache->tmp_file_name();
+  if (cache_path == nullptr || cache_path[0] == '\0') return -1;
+
+  uint32_t reserved_bytes = cache->file_reserved_bytes();
+  if (reserved_bytes == 0) return -1;
+
+  /* Step 1: Sync cache file data to disk */
+  if (cache->sync_to_disk()) return -1;
+
+  my_off_t cache_data_size = cache->length();
+  my_off_t total_file_size = reserved_bytes + cache_data_size;
+
+  /* Step 2: Acquire LOCK_log */
+  mysql_mutex_lock(&LOCK_log);
+
+  if (unlikely(!is_open())) {
+    mysql_mutex_unlock(&LOCK_log);
+    return -1;
+  }
+
+  /* Step 2b: Assign GTID */
+  thd->next_to_commit = nullptr;
+  if (assign_automatic_gtids_to_flush_group(thd)) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+  /* Step 3: Rotate binlog. Creates new binlog with header events. */
+  int error = new_file_without_locking(nullptr);
+  if (error) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+  /* Header size = position in the new binlog after FDE + Previous_gtids */
+  my_off_t header_size = m_binlog_file->position();
+
+  /* Step 4: Create GTID event */
+  Transaction_ctx *trn_ctx = thd->get_transaction();
+  trn_ctx->sequence_number = m_dependency_tracker.step();
+  int64 sequence_number = trn_ctx->sequence_number;
+  int64 last_committed = sequence_number - 1;
+  trn_ctx->last_committed = SEQ_UNINIT;
+
+  ulonglong immediate_commit_timestamp = my_micro_time();
+  ulonglong original_commit_timestamp =
+      thd->variables.original_commit_timestamp;
+  if (original_commit_timestamp == UNDEFINED_COMMIT_TIMESTAMP) {
+    if (thd->slave_thread || thd->is_binlog_applier())
+      original_commit_timestamp = 0;
+    else
+      original_commit_timestamp = immediate_commit_timestamp;
+  } else {
+    thd->variables.original_commit_timestamp = UNDEFINED_COMMIT_TIMESTAMP;
+  }
+
+  uint32_t trx_immediate_server_version =
+      do_server_version_int(::server_version);
+  thd->variables.immediate_server_version = UNDEFINED_SERVER_VERSION;
+
+  uint32_t trx_original_server_version = thd->variables.original_server_version;
+  if (trx_original_server_version == UNDEFINED_SERVER_VERSION) {
+    if (thd->slave_thread || thd->is_binlog_applier())
+      trx_original_server_version = UNKNOWN_SERVER_VERSION;
+    else
+      trx_original_server_version = trx_immediate_server_version;
+  } else {
+    thd->variables.original_server_version = UNDEFINED_SERVER_VERSION;
+  }
+
+  Gtid_log_event gtid_event(
+      thd, cache_data->is_trx_cache(), last_committed, sequence_number,
+      cache_data->may_have_sbr_stmts(), original_commit_timestamp,
+      immediate_commit_timestamp, trx_original_server_version,
+      trx_immediate_server_version);
+
+  /* Serialize GTID event to buffer using StringBuffer_ostream */
+  StringBuffer_ostream<256> gtid_buf;
+
+  /*
+    We need to set end_log_pos for the GTID event. Since checksums are OFF
+    and events in cache also don't have checksums, no checksum handling needed.
+    The GTID event's log_pos should be its start position in the final file.
+  */
+  gtid_event.common_header->log_pos = header_size;
+  gtid_event.common_footer->checksum_alg =
+      binary_log::BINLOG_CHECKSUM_ALG_OFF;
+
+  /*
+    Compute transaction_length. It spans from GTID event through all
+    transaction events including any filler event in between.
+    transaction_length = total_file_size - header_size
+  */
+  gtid_event.set_trx_length_by_cache_size(
+      cache_data->get_byte_position(), false /* is_checksum_enabled */,
+      cache_data->get_event_counter());
+
+  if (binary_event_serialize(&gtid_event, &gtid_buf)) {
+    m_binlog_file->close();
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+  size_t gtid_size = gtid_buf.length();
+
+  /* Check if reserved space is sufficient */
+  if (header_size + gtid_size > reserved_bytes) {
+    /*
+      Reserved space is too small. Can't do rename. Undo the rotation
+      and fall back to normal ordered_commit. This is a rare edge case.
+    */
+    /* TODO: undo rotation gracefully. For now, just fail. */
+    mysql_mutex_unlock(&LOCK_log);
+    return -1;
+  }
+
+  size_t filler_size = reserved_bytes - header_size - gtid_size;
+
+  /* Recalculate transaction_length including filler if needed */
+  if (filler_size > 0 && filler_size >= LOG_EVENT_HEADER_LEN) {
+    /*
+      transaction_length should be: gtid_size + filler_size + cache_data_size
+      But set_trx_length_by_cache_size already computed it as
+      gtid_size + cache_data_size. Need to add filler_size.
+      Re-serialize the GTID event after adjusting.
+    */
+    ulonglong adjusted_trx_len =
+        gtid_size + filler_size + cache_data_size;
+    gtid_event.transaction_length = adjusted_trx_len;
+
+    /* Clear and re-serialize */
+    gtid_buf.length(0);
+    if (binary_event_serialize(&gtid_event, &gtid_buf)) {
+      m_binlog_file->close();
+      mysql_mutex_unlock(&LOCK_log);
+      return 1;
+    }
+    size_t new_gtid_size = gtid_buf.length();
+    if (new_gtid_size != gtid_size) {
+      /*
+        GTID event size changed due to transaction_length encoding.
+        Recalculate filler and retry once.
+      */
+      gtid_size = new_gtid_size;
+      filler_size = reserved_bytes - header_size - gtid_size;
+      if (header_size + gtid_size > reserved_bytes ||
+          (filler_size > 0 && filler_size < LOG_EVENT_HEADER_LEN)) {
+        mysql_mutex_unlock(&LOCK_log);
+        return -1;
+      }
+      adjusted_trx_len = gtid_size + filler_size + cache_data_size;
+      gtid_event.transaction_length = adjusted_trx_len;
+      gtid_buf.length(0);
+      if (binary_event_serialize(&gtid_event, &gtid_buf)) {
+        m_binlog_file->close();
+        mysql_mutex_unlock(&LOCK_log);
+        return 1;
+      }
+      gtid_size = gtid_buf.length();
+      filler_size = reserved_bytes - header_size - gtid_size;
+    }
+  } else if (filler_size > 0 && filler_size < LOG_EVENT_HEADER_LEN) {
+    /* Gap too small for even a minimal event. Fall back. */
+    mysql_mutex_unlock(&LOCK_log);
+    return -1;
+  }
+
+
+  /* Step 5: Read header from new binlog file and write to cache file */
+  {
+    File src_fd = mysql_file_open(key_file_binlog, log_file_name,
+                                  O_RDONLY, MYF(MY_WME));
+    if (src_fd < 0) {
+      mysql_mutex_unlock(&LOCK_log);
+      return 1;
+    }
+
+    uchar buf[IO_SIZE];
+    my_off_t copied = 0;
+    while (copied < header_size) {
+      size_t to_read = std::min(static_cast<size_t>(header_size - copied),
+                                sizeof(buf));
+      size_t nread = mysql_file_read(src_fd, buf, to_read, MYF(MY_WME));
+      if (nread == (size_t)-1 || nread == 0) {
+        mysql_file_close(src_fd, MYF(0));
+        mysql_mutex_unlock(&LOCK_log);
+        return 1;
+      }
+      if (mysql_file_pwrite(cache_fd, buf, nread, copied,
+                            MYF(MY_WME | MY_NABP))) {
+        mysql_file_close(src_fd, MYF(0));
+        mysql_mutex_unlock(&LOCK_log);
+        return 1;
+      }
+      copied += nread;
+    }
+    mysql_file_close(src_fd, MYF(0));
+  }
+
+  /* Step 6: Write GTID event to cache file */
+  if (mysql_file_pwrite(cache_fd,
+                        pointer_cast<const uchar *>(gtid_buf.ptr()),
+                        gtid_size, header_size, MYF(MY_WME | MY_NABP))) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+  /* Step 7: Write filler event if there's a gap */
+  if (filler_size >= LOG_EVENT_HEADER_LEN) {
+    my_off_t filler_offset = header_size + gtid_size;
+    uint32 filler_end_pos = static_cast<uint32>(filler_offset + filler_size);
+    if (write_ignorable_filler(cache_fd, filler_offset,
+                               static_cast<uint32>(filler_size),
+                               filler_end_pos)) {
+      mysql_mutex_unlock(&LOCK_log);
+      return 1;
+    }
+  }
+
+  /* Step 8: Fix up end_log_pos in all transaction events */
+  if (fixup_event_positions(cache_fd, reserved_bytes, total_file_size)) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+  /* Step 9: Sync the modified cache file */
+  if (mysql_file_sync(cache_fd, MYF(0))) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+
+  /* Step 10: Close the new (mostly empty) binlog file */
+  m_binlog_file->close();
+
+  /* Step 11: Delete the new binlog and rename cache file */
+  if (my_delete(log_file_name, MYF(MY_WME))) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+  if (my_rename(cache_path, log_file_name, MYF(MY_WME))) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+  /* Step 12: Reopen the renamed file as the active binlog */
+  {
+    auto new_ofile = Binlog_ofile::open_existing(
+        key_file_binlog, log_file_name, MYF(MY_WME));
+    if (!new_ofile) {
+      mysql_mutex_unlock(&LOCK_log);
+      return 1;
+    }
+
+    delete m_binlog_file;
+    m_binlog_file = new_ofile.release();
+  }
+
+  /*
+    Position the write cursor at the end of the file.
+    truncate(total_file_size) is a no-op for the file size but
+    reinitializes the IO_CACHE write position and sets m_position.
+  */
+  if (m_binlog_file->truncate(total_file_size)) {
+    mysql_mutex_unlock(&LOCK_log);
+    return 1;
+  }
+
+
+  /* Step 13: Set transaction position and update binlog end position */
+  thd->set_trans_pos(log_file_name, m_binlog_file->position());
+
+  if (cache_data->has_xid()) inc_prep_xids(thd);
+
+  update_binlog_end_pos();
+
+  /* Step 14: Detach cache from the (now-renamed) file */
+  cache->detach_temp_file();
+
+  mysql_mutex_unlock(&LOCK_log);
+
+
+  /* Step 15: Engine commit */
+  init_thd_variables(thd, all, skip_commit);
+  ::finish_transaction_in_engines(thd, all, false);
+
+
+  /* Step 16: GTID state update */
+  if (thd->commit_error == THD::CE_NONE) {
+    gtid_state->update_on_commit(thd);
+  } else {
+    gtid_state->update_on_rollback(thd);
+  }
+
+  /* Step 17: Unfence rotation and reset cache */
+  if (cache_data->has_xid()) {
+    trx_coordinator::set_prepared_in_tc_in_engines(thd, all);
+    dec_prep_xids(thd);
+  }
+
+  /* Run after_commit hook */
+  if (thd->commit_error != THD::CE_COMMIT_ERROR &&
+      thd->get_transaction()->m_flags.run_hooks) {
+    (void)RUN_HOOK(transaction, after_commit, (thd, all));
+    thd->get_transaction()->m_flags.run_hooks = false;
+  }
+
+  cache_mngr->reset();
+
+  return thd->commit_error == THD::CE_COMMIT_ERROR ? 1 : 0;
+}

+   along with this program; if not, write to the Free Software
+   Foundation, Inc., 51 Franklin St, Fifth Floor, Boston, MA 02110-1301  USA */
+
+#include "sql/binlog_large_commit.h"
+
+#include <cstring>
+
+#include "my_dir.h"
+#include "my_sys.h"
+#include "mysql/components/services/log_builtins.h"
+#include "mysqld_error.h"
+#include "sql/binlog.h"
+#include "sql/log.h"
+#include "sql/mysqld.h"
+
+static const char *BINLOG_CACHE_DIR_NAME = "#binlog_cache_files";
+static const char *CACHE_FILE_PREFIX = "ML_";
+
+ulonglong opt_binlog_large_commit_threshold = 128ULL * 1024ULL * 1024ULL;
+char binlog_cache_dir[FN_REFLEN];
+
+static std::atomic<uint32_t> s_reserve_bytes{BINLOG_CACHE_RESERVE_DEFAULT};
+
+uint32_t get_binlog_cache_reserve_bytes() { return s_reserve_bytes.load(); }
+
+void set_binlog_cache_reserve_bytes(uint32_t header_len) {
+  /*
+    Reserve space for: binlog header events + Gtid_log_event.
+    Gtid_log_event max size: LOG_EVENT_HEADER_LEN(19) + max_data(~79)
+    + checksum(4) ≈ 102 bytes. Conservatively use 512 for GTID.
+  */
+  uint32_t total = header_len + 512;
+
+  /* Align to IO_SIZE (512 bytes) */
+  static_assert((IO_SIZE & (IO_SIZE - 1)) == 0, "IO_SIZE must be power of 2");
+  total = (total + (IO_SIZE - 1)) & ~(IO_SIZE - 1);
+
+  s_reserve_bytes.store(total);
+}
+
+bool init_binlog_cache_dir() {
+  if (opt_binlog_large_commit_threshold == 0) return false;
+
+  size_t basedir_len;
+  dirname_part(binlog_cache_dir, log_bin_basename, &basedir_len);
+
+  size_t dir_name_len = strlen(BINLOG_CACHE_DIR_NAME);
+  if (basedir_len + dir_name_len + 1 + strlen(CACHE_FILE_PREFIX) + 20 >=
+      FN_REFLEN) {
+    LogErr(ERROR_LEVEL, ER_BINLOG_LOGGING_NOT_POSSIBLE,
+           "binlog cache directory path is too long");
+    return true;
+  }
+
+  memcpy(binlog_cache_dir + basedir_len, BINLOG_CACHE_DIR_NAME, dir_name_len);
+  binlog_cache_dir[basedir_len + dir_name_len] = '\0';
+
+  MY_DIR *dir_info = my_dir(binlog_cache_dir, MYF(0));
+  if (!dir_info) {
+    if (my_mkdir(binlog_cache_dir, 0777, MYF(0)) < 0) {
+      LogErr(ERROR_LEVEL, ER_BINLOG_LOGGING_NOT_POSSIBLE,
+             "could not create #binlog_cache_files directory");
+      return true;
+    }
+    return false;
+  }
+
+  /* Clean up stale cache files from previous server instance */
+  for (uint i = 0; i < dir_info->number_off_files; i++) {
+    FILEINFO *file = dir_info->dir_entry + i;
+    if (file->name[0] == '.') continue;
+    if (strncmp(file->name, CACHE_FILE_PREFIX, strlen(CACHE_FILE_PREFIX)) !=
+        0) {
+      sql_print_warning(
+          "Unexpected file '%s' in #binlog_cache_files/, skipping",
+          file->name);
+      continue;
+    }
+    char file_path[FN_REFLEN];
+    fn_format(file_path, file->name, binlog_cache_dir, "",
+              MYF(MY_REPLACE_DIR));
+    my_delete(file_path, MYF(0));
+  }
+
+  my_dirend(dir_info);
+  return false;
+}
